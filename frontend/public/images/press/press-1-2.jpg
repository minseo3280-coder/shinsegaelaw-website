    </script>

    <script>
        new Swiper('.y_caseLayout .sB',{
            slidesPerView: 3,
            spaceBetween: 5+'%',
            loop : true,
            autoplay: {
                delay: 3000,
                disableOnInteraction : false
            },
            navigation: {
                nextEl: '.y_caseLayout .sBback .btn a.next',
                prevEl: '.y_caseLayout .sBback .btn a.prev',
            },
            pagination: {
                el: '.y_caseLayout .sBback .swiper-pagination',
                type: 'bullets',
                clickable: true
            },
            breakpoints: {
                1090: {
                    slidesPerView: 2,
                },
                768: {
                    slidesPerView: 1,
                    spaceBetween: 10,
                },
            },
        });

    </script>

    <script>

        var se01Event = {
            init : function(){
                this.motion();
            },
            motion : function(){
                $('.section01 .list dt em').counterUp({
                    delay: 10,
                    time: 800
                });
            }
        }

        var se02Event = {
            init : function(){
                this.motion();
                this.layout();
            },
            layout : function(){
                var ww = window.innerWidth;

            },
            motion : function(){
                var ww = window.innerWidth;

                window.addEventListener('resize',function(){
                    ww = window.innerWidth;
                    if (ww >= 769){
                        se02ScrollEvent();
                    }else{
                        se02ScrollRemove();
                    }
                });

                if (ww >= 769){
                    se02ScrollEvent();
                }else{
                    se02ScrollRemove();
                }

                function se02ScrollEvent(){
                    window.addEventListener('scroll',function(){
                        ww = window.innerWidth;

                        if (ww >= 769){
                            var offset = pageYOffset;
                            var se02Top = $('.section02').offset().top;
                            var sbHeight = $('.section02 .searchbox').outerHeight();
                            var sbMax = offset + sbHeight;
                            var se03OffsetTop = $('.section03').offset().top;

                            if (offset >= se02Top && sbMax < se03OffsetTop){
                                $('.section02 .searchbox').css({'position':'fixed','top':'0','bottom':'auto'});
                            }else if (offset >= se02Top && sbMax >= se03OffsetTop){
                                $('.section02 .searchbox').css({'position':'absolute','bottom':'0','top':'auto'});
                            }else if (offset < se02Top && sbMax < se03OffsetTop){
                                $('.section02 .searchbox').css({'position':'absolute','top':'0','bottom':'auto'});
                            }
                        }else{
                            return;
                        }
                    });
                }

                function se02ScrollRemove(){
                    $('.section02 .searchbox').css({'position':'static'});
                }

            }
        }

        var se03Event = {
            init : function(){
                this.motion();
                this.layout();
            },
            layout : function(){
                var ww = window.innerWidth;

            },
            motion : function(){
                var ww = window.innerWidth;
                var overSlide = undefined;
                function initOverSlide() {
                    if (ww > 768 && overSlide == undefined){
                        overSlide = new Swiper('.section03 .contslide',{
                            effect: 'fade',
                            fadeEffect: {
                                crossFade: true
                            },
                            speed: 600,
                            autoplay: {
                                delay: 3000,
                                disableOnInteraction: false,
                            },
                            on: {
                                slideChange : function (){
                                    $('.section03 .overslide li').removeClass('over');
                                    $('.section03 .overslide li').eq(this.realIndex).addClass('over');
                                    var changeBg = ''
                                    switch (this.realIndex) {
                                        case 0 :
                                            changeBg = '/img/overslideBg.jpg'
                                        break;
                                        case 1 :
                                            changeBg = '/img/overslideImg02_bg.jpg'
                                        break;
                                        case 2 :
                                            changeBg = '/img/overslideBg3.jpg'
                                        break;
                                        case 3 :
                                            changeBg = '/img/overslideBg4.jpg'
                                        break;
                                    }
                                    $('.section03').css({'background-image':'url('+changeBg+')'});
                                }
                            }
                        });
                    } else if (ww <= 768 && overSlide != undefined){
                        overSlide.destroy();
                        overSlide = undefined;
                    }
                }initOverSlide();

                window.addEventListener('resize',function(){
                    ww = window.innerWidth;
                    initOverSlide();
                });

                $('.section03 .overslide li').on('click',function(){
                    var index = $(this).index();
                    if (overSlide != undefined){
                        overSlide.slideTo(index);
                    }else{
                        return;
                    }
                    $(this).siblings().removeClass('over');
                    $(this).addClass('over');
                });

            }
        }


        var se04Event = {
            init : function(){
                this.motion();
            },
            motion : function(){
                var se04Slide = new Swiper('.section04 .s4Slide',{
                    speed: 600,
                    autoplay: {
                        delay: 3000,
                    },
                    slidesPerView: 3.5,
                    spaceBetween: 30,
                    loop : true,
                    loopedSlides : 4,
                    autoplay: {
                        delay: 3000,
                        disableOnInteraction : false
                    },
                    navigation: {
                        nextEl: '.section04 .slidebox .btn a:last-child',
                        prevEl: '.section04 .slidebox .btn a:first-child',
                    },
                    breakpoints: {
                        1250 : {
                            slidesPerView: 2.5,
                        },
                        768: {
                            slidesPerView: 1.5,
                            centeredSlides: true,
                            spaceBetween: 30,
                            loopedSlides : 1,
                        }
                    },
                    on : {
                        init : function(){
                            $('.section04 .pagenumber .total').text((this.slides.length - 2));
                            $('.section04 .s4Slide .swiper-slide').hover(
                                function(){
                                    var ww = window.innerWidth;
                                    if (ww >=769){
                                        $(this).find('.overtext h2 ~ *').stop().slideDown(300);
                                    }else {
                                        return;
                                    }
                                },
                                function(){
                                    var ww = window.innerWidth;
                                    if (ww >=769){
                                        $(this).find('.overtext h2 ~ *').stop().slideUp(300);
                                    }else {
                                        return;
                                    }
                            });
                        },
                        slideChangeTransitionStart : function(){
                            $('.section04 .pagenumber li.number .to').text(''+(this.realIndex + 1)+' /');
                        }
                    }
                });

                $('.section04 .pagenumber li.prev').click(function(){
                    se04Slide.slidePrev();
                });

                $('.section04 .pagenumber li.next').click(function(){
                    se04Slide.slideNext();
                });
            }
        }

        window.addEventListener('DOMContentLoaded',function(){
            se01Event.init();
            se02Event.init();
            se03Event.init();
            se04Event.init();
            AOS.init({
                duration: 800,
            });
        });
    </script>




