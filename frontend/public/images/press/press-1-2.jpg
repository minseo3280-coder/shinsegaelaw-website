    <script>

        $('.inq_area .rbx .cont .cover span').click(function () {
            $(this).parent('.cover').addClass('hide');
        });


        $('.inq_area .lbx .start').click(function () {
            if($(window).innerWidth() <= 768){
            
                $(this).parent('.lbx').addClass('hide');

            }  
        });

        
		
	$(document).ready(function() {
		
        $('#fsubmit3_next').click(function () {
			
			if ($("input[name='k_2[]']:checked").length < 1) {
				alert("필요한 서류를 1개 이상 선택해주세요");
				return false;
			}
			
            $(this).parents('.a_').parents('.cont').addClass('hide');
            $(this).parents('.a_').parents('.cont').siblings('.cont._2').addClass('show');
            $(this).parents('.a_').parents('.cont').parents('.answer').siblings('.top').find('.line span').css('width', '100%');
            $(this).parents('.a_').parents('.cont').parents('.answer').siblings('.top').find('.pag span').text('2');
        });
		
		$(document).on('click', '#fsubmit3', function() {
			
			let regExp = /([\w-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([\w-]+\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\]?)$/;
			
            /* Acecounter 버튼스크립트 추가_250228 */
            try {
            _PL('https://www.shinsegaelaw.kr/lib/fastinquiry/write.proc.php');
            } catch (e) {}

			var f = document.mainform3;

			if (!$('input:checkbox[name=agree3]').is(':checked')) {
				alert("개인정보 수집 및 이용목적에 동의해주세요");
				return false;
			}
			
			if (f.f_name.value == "")
			{
				alert("이름을 입력해주세요");
				f.f_name.focus();
				return false;
			}

			if (f.f_phone.value == "")
			{
				alert("연락처를 입력해주세요");
				f.f_phone.focus();
				return false;
			}
			
			if (f.k_3.value == "")
			{
				alert("이메일을 입력해주세요");
				f.k_3.focus();
				return false;
			}
			
			if (!regExp.test(f.k_3.value)) {
				alert("이메일 형식에 맞게 입력해주세요");
				return false;
			}
		
			var params = jQuery("#mainform3").serialize();
			
			$.ajax({
				type : 'POST',
				url :  '/lib/fastinquiry/write.proc.php',
				data : params,
				dataType : "json",
				success : function(data) {
					
					if (data.result == 'suc') {
                        if(window.wcs){
                            if(!wcs_add) var wcs_add = {};
                            wcs_add["wa"] = "s_2f6c54843682";
                            var _conv = {};
                                _conv.type = 'custom001';
                            wcs.trans(_conv);
                        }

                        // Pixel 전환코드 250509
                        fbq('track', 'CompleteRegistration');
						// ADN Tracker
                        try{
                            acrossADN_complete_btn_ok("109447", "types2", "2");
                        } catch(e) {
                            console.log('ADN tracker Error:',e)
                        }

                        alert('빠른 상담문의가 접수되었습니다.');
						// gtag_sms();
						//초기화
						$('#mainform3 #f_name').val("");
						$('#mainform3 #f_phone').val("");
						$('#mainform3 #k_3').val("");
						$("input:checkbox[name='agree3']").attr("checked", false);
						$("#mainform3 input[name='k_2[]']").attr("checked", false);
					} else {
						alert('Error');
					}

				}, error : function (){
					alert("Error");
				}

			});


		});	

	});
	
	</script>


