				<script type="text/javascript">
					$(document).ready(function(e) {
						$(".error_header .category > li").bind("mouseenter mouseleave", function (e) {
							if(e.type == "mouseenter") {
								$(this).find(".sub").show();
								$(this).siblings("li").find(".sub").hide();
							} else {
								$(this).parent().find(".sub").hide();
							}
						});
						$(".error_header .category a").bind("focusin", function (e) {
							if(e.type == "focusin") {
								$(this).closest(".error_header .category > li").find(".sub").show();
								$(this).closest(".error_header .category > li").siblings("li").find(".sub").hide();
							}
						});
					});
				</script>

